# Sigma PMO — backend production env
#
# Save (without comments) to /etc/sigma-pmo/backend.env
# Mode 0640 root:sigma so systemd can read but no one else can.

# Runtime
NODE_ENV=production
PORT=3001

# Database
DB_TYPE=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=sigma_pmo
DB_PASS=REPLACE_WITH_STRONG_PASSWORD
DB_NAME=sigma_pmo
# Forced false in code when NODE_ENV=production — kept here for clarity.
DB_SYNCHRONIZE=false

# Storage (immutable source-file archive)
STORAGE_DIR=/srv/sigma-pmo/storage/files
SAMPLES_DIR=/srv/sigma-pmo/data/samples

# Auth + bootstrap
# Hex token (eg openssl rand -hex 32). REQUIRED to bootstrap first admin in prod.
# Delete this line once the first admin is created.
BOOTSTRAP_TOKEN=REPLACE_WITH_HEX_32

# Body size + rate limits
BODY_LIMIT_MB=25
THROTTLE_DEFAULT_LIMIT=100
THROTTLE_DEFAULT_TTL=60
THROTTLE_AUTH_LIMIT=10
THROTTLE_AUTH_TTL=60
THROTTLE_INGEST_LIMIT=30
THROTTLE_INGEST_TTL=60

# CORS — set to the frontend's public origin
CORS_ORIGIN=https://app.sigma.example

# Observability (optional)
SENTRY_DSN=
LOG_LEVEL=info

# Email (optional — falls back to log channel if unset)
EMAIL_SMTP_URL=
EMAIL_FROM=Sigma PMO <noreply@sigma.example>

# Slack / Teams outbound webhooks (optional)
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# ---
# Sigma PMO — frontend production env
# Save to /etc/sigma-pmo/frontend.env
# ---
# NODE_ENV=production
# PORT=3000
# HOSTNAME=127.0.0.1
# NEXT_PUBLIC_API_BASE=/api/v1
# NEXT_PUBLIC_BRAND_NAME=Sigma PMO

# ---
# Sigma PMO — backup cron env
# Save to /etc/sigma-pmo/backup.env, mode 0600 sigma:sigma
# ---
# SIGMA_DB_USER=sigma_pmo
# SIGMA_DB_PASS=REPLACE_WITH_STRONG_PASSWORD
# SIGMA_DB_NAME=sigma_pmo
# SIGMA_OFFSITE_RSYNC=user@offsite.example:/backups/sigma-pmo
