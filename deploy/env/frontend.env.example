# Sigma PMO frontend production environment.
# Copy to /etc/sigma-pmo/frontend.env and replace the domain.

NODE_ENV=production
PORT=3000
HOSTNAME=127.0.0.1
NEXT_PUBLIC_API_BASE=https://sigma-pmo.com/api/v1

# One-click demo user-picker on the login page. Set to false to hide it and
# require manual email/password sign-in (recommended for real production).
NEXT_PUBLIC_DEMO_LOGIN=true

