# Sigma PMO backup job environment.
# Copy to /etc/sigma-pmo/backup.env, chmod 0600, and chown sigma:sigma.

SIGMA_DB_USER=sigma_pmo
SIGMA_DB_NAME=sigma_pmo
SIGMA_DB_PASS=REPLACE_STRONG_DB_PASSWORD

# Optional off-host backup target. Example:
# SIGMA_OFFSITE_RSYNC=backup-user@backup-host:/srv/backups/sigma-pmo
SIGMA_OFFSITE_RSYNC=

