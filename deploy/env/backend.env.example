# Sigma PMO backend production environment.
# Copy to /etc/sigma-pmo/backend.env and replace every REPLACE_* value.

NODE_ENV=production
PORT=3001

# File storage
STORAGE_DIR=/srv/sigma-pmo/storage/files
SAMPLES_DIR=/srv/sigma-pmo/data/samples
BODY_LIMIT=25mb

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=sigma_pmo
DB_PASSWORD=REPLACE_STRONG_DB_PASSWORD
DB_DATABASE=sigma_pmo
DB_SYNCHRONIZE=false
DB_LOGGING=false

# Security and access
CORS_ORIGINS=https://sigma-pmo.com,https://www.sigma-pmo.com
# Public site URL — used in Stripe redirects + per-company login links.
APP_PUBLIC_URL=https://sigma-pmo.com
BOOTSTRAP_TOKEN=REPLACE_LONG_RANDOM_BOOTSTRAP_TOKEN
RATE_LIMIT_DEFAULT_LIMIT=100
RATE_LIMIT_DEFAULT_TTL_MS=60000
RATE_LIMIT_AUTH_LIMIT=10
RATE_LIMIT_INGEST_LIMIT=30

# Logging and monitoring
LOG_LEVEL=info
# SENTRY_DSN=

# Outbound notification channels
# EMAIL_SMTP_URL=smtp://user:pass@smtp.example.com:587
# SLACK_WEBHOOK_URL=
# TEAMS_WEBHOOK_URL=

# Optional LLM narrative support. Leave empty for deterministic-only mode.
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-5
ANTHROPIC_DEFAULT_TIER=claude-sonnet
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_CACHE_TTL=3600

# REQUIRED in production — encrypts the secrets stored via /admin/settings
# (Claude API key, SMTP, …). Without it the app falls back to a weak derived
# dev key. Generate: openssl rand -hex 32
SETTINGS_ENCRYPTION_KEY=REPLACE_64_HEX_CHARS

# Object storage — Cloudflare R2 / any S3-compatible provider. Drives the file
# archive (StorageService) AND the encrypted DB backups. Leave blank for local
# disk. R2: region "auto" + path-style.
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=true
# S3_SSE=AES256

# Encrypted DB backups to S3 (scripts/backup-db-to-s3.ts). Generate: openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=
BACKUP_RETENTION=14

# Stripe billing (optional). When STRIPE_SECRET_KEY + STRIPE_PRICE_ID are set,
# registration sends the new company to Stripe Checkout with a free trial.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
STRIPE_TRIAL_DAYS=30

