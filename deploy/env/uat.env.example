# ─────────────────────────────────────────────────────────────────────────────
# Sigma PMO — UAT environment (Product-Owner testing with REAL data).
# Real authentication only. NO sample accounts, NO one-click login, NO public
# admin. Use real users created via registration or the admin console.
# ─────────────────────────────────────────────────────────────────────────────

# Posture — locked down
APP_ENV=uat
SEED_DEMO=false                # do NOT seed sample accounts
DEMO_LOGIN_PUBLIC=false        # sample accounts cannot authenticate (API-enforced)
ADMIN_SEED_PASSWORD=           # leave empty — no seeded admin

# Frontend build args
NEXT_PUBLIC_DEMO_LOGIN=false   # hide the one-click picker entirely
NEXT_PUBLIC_API_BASE=https://uat-api.sigma-pmo.com/api/v1

# Public URLs
APP_PUBLIC_URL=https://uat.sigma-pmo.com
CORS_ORIGINS=https://uat.sigma-pmo.com

# Database (separate from demo/prod)
DB_DATABASE=sigma_pmo_uat
DB_SYNCHRONIZE=false

# Secrets — generate fresh, unique per environment
SETTINGS_ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_HEX
BACKUP_ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_HEX
BOOTSTRAP_TOKEN=REPLACE        # required to create the first real admin in prod-mode
# ANTHROPIC_API_KEY, S3_*, STRIPE_* — set as needed.

# First admin (UAT): with no users yet, create one via the bootstrap token:
#   curl -X POST .../auth/users -H "x-bootstrap-token: $BOOTSTRAP_TOKEN" ...
# or the CLI: npm run user:create -- you@org.com sigma_admin "StrongPw!" "Your Name"
