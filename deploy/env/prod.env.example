# ─────────────────────────────────────────────────────────────────────────────
# Sigma PMO — PRODUCTION environment (commercial clients).
# No demo accounts, no one-click login, no shared credentials, no public admin.
# Each company is an isolated tenant; subscriptions/trials are enforced.
# ─────────────────────────────────────────────────────────────────────────────

# Posture — fully locked down
APP_ENV=production
NODE_ENV=production
SEED_DEMO=false
DEMO_LOGIN_PUBLIC=false
ADMIN_SEED_PASSWORD=

# Frontend build args
NEXT_PUBLIC_DEMO_LOGIN=false
NEXT_PUBLIC_API_BASE=https://app-api.sigma-pmo.com/api/v1

# Public URLs
APP_PUBLIC_URL=https://app.sigma-pmo.com
CORS_ORIGINS=https://app.sigma-pmo.com

# Database (dedicated)
DB_DATABASE=sigma_pmo
DB_SYNCHRONIZE=false

# Rate limits — keep the tight production defaults (do NOT raise like dev)
# RATE_LIMIT_AUTH_LIMIT=10

# Secrets — generate fresh, unique, store only in the secret manager
SETTINGS_ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_HEX
BACKUP_ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_HEX
BOOTSTRAP_TOKEN=REPLACE
# ANTHROPIC_API_KEY — set in the admin console (encrypted SystemSetting) or env.
# S3_* — Cloudflare R2 / S3 for the file archive + encrypted DB backups.
# STRIPE_SECRET_KEY / STRIPE_PRICE_ID / STRIPE_WEBHOOK_SECRET — live billing.

# AI provider is Anthropic Claude only (no OpenAI). Leave LLM_PROVIDER=anthropic.
LLM_PROVIDER=anthropic
