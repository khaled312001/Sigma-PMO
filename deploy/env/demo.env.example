# ─────────────────────────────────────────────────────────────────────────────
# Sigma PMO — DEMO environment (controlled demonstrations only).
# Sample companies + sample users + non-sensitive data. The one-click sample
# login is ON, but the platform admin is NOT public and NOT one-click.
# Copy to your host / Coolify "Environment Variables". Secrets are placeholders.
# ─────────────────────────────────────────────────────────────────────────────

# Posture
APP_ENV=demo
SEED_DEMO=true                 # seed the sample company + role accounts
DEMO_LOGIN_PUBLIC=true         # one-click sample login allowed (demo only)
DEMO_SEED_PASSWORD=Sigma$Demo2026          # rotate this per deploy
ADMIN_SEED_PASSWORD=CHANGE-ME-private-admin-pw   # private admin (NOT in the picker)

# Frontend build args (inlined at build time)
NEXT_PUBLIC_DEMO_LOGIN=true
NEXT_PUBLIC_DEMO_PASSWORD=Sigma$Demo2026   # MUST match DEMO_SEED_PASSWORD
NEXT_PUBLIC_API_BASE=https://demo-api.sigma-pmo.com/api/v1

# Public URLs
APP_PUBLIC_URL=https://demo.sigma-pmo.com
CORS_ORIGINS=https://demo.sigma-pmo.com

# Database
DB_DATABASE=sigma_pmo_demo
DB_SYNCHRONIZE=false

# Secrets (generate your own; never commit real values)
SETTINGS_ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_HEX
BACKUP_ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_HEX
BOOTSTRAP_TOKEN=REPLACE
# ANTHROPIC_API_KEY, S3_*, STRIPE_* — set as needed.
