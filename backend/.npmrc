# Sigma PMO backend — npm is the ONLY supported package manager.
# One lockfile (package-lock.json). Do not introduce pnpm-lock.yaml or yarn.lock.
# engine-strict enforces the Node/npm versions declared in package.json "engines"
# so a clean `npm ci` is deterministic across machines and the production image
# (node:20-alpine). See RUNBOOK.md.
engine-strict=true
save-exact=true
