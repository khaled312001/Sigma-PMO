# Sigma PMO — backend environment template. Copy to ".env" and adjust.

# Application
NODE_ENV=development
PORT=3001

# Where ingested source files are archived immutably (relative to backend/ cwd).
STORAGE_DIR=../data/storage

# Database (MySQL). Local dev defaults shown; production values come from Hostinger.
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=sigma_pmo
# Auto-create schema from entities (DEV ONLY). Set false in production (use migrations).
DB_SYNCHRONIZE=true
DB_LOGGING=false
