# Sigma PMO — backend environment template. Copy to ".env" and adjust.

# Application
NODE_ENV=development
PORT=3001

# Where ingested source files are archived immutably (relative to backend/ cwd).
STORAGE_DIR=../data/storage
# Where synthetic + sample input files live (allowlisted for `ingest-path`).
SAMPLES_DIR=../data/samples

# Database (MySQL). Local dev defaults shown; production values come from Hostinger.
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=sigma_pmo
# Auto-create schema from entities. Keep false for real/local UAT data; use
# migrations or sample-data scripts instead of runtime schema rewrites.
DB_SYNCHRONIZE=false
DB_LOGGING=false

# HTTP body size limit (used for /ingestion/upload). Aligns with DTO MaxLength.
BODY_LIMIT=25mb

# Logging
# trace | debug | info | warn | error | fatal
LOG_LEVEL=debug

# Sentry (optional). When set, errors are reported to Sentry.
# SENTRY_DSN=

# Bootstrap token. Required in production to perform first-admin creation
# while no users exist. Provide via `x-bootstrap-token` header.
# BOOTSTRAP_TOKEN=

# Rate limits (per-IP, per-minute). Production defaults shown.
RATE_LIMIT_DEFAULT_LIMIT=100
RATE_LIMIT_DEFAULT_TTL_MS=60000
RATE_LIMIT_AUTH_LIMIT=10
RATE_LIMIT_INGEST_LIMIT=30

# CORS — comma-separated origins. Leave empty for default http://localhost:3000.
# CORS_ORIGINS=https://app.sigma-pmo.example.com

# Outbound notification channels (optional). SMTP can also be set (encrypted) at
# /admin/settings (key integrations.email_smtp) — that takes precedence over the
# env var. Prove it end-to-end: GET /notifications/status, POST /notifications/test-email,
# or POST /reports/monthly/:id/email. EMAIL_FROM is the sender (e.g. info@sigma-pmo.com).
# EMAIL_SMTP_URL=smtp://user:pass@smtp.example.com:587
# EMAIL_FROM=info@sigma-pmo.com
# SLACK_WEBHOOK_URL=
# TEAMS_WEBHOOK_URL=

# LLM (optional, legacy). When LLM_API_KEY is unset, summaries are deterministic only.
# This block stays for backward compatibility with the Wave 1 LlmService prose
# rewriter; the Wave 2 direct Claude wiring uses the ANTHROPIC_* block below.
# LLM_API_KEY=
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-6
# LLM_MAX_TOKENS=1024

# ─────────────────────────────────────────────────────────────────────────────
# Anthropic Claude API (Wave 2 — direct SDK wiring for personas, FIDIC drafts,
# clash solution proposer, monthly narrative).
#
# DETERMINISTIC-ONLY MODE: when ANTHROPIC_API_KEY is empty or unset, the entire
# system stays in deterministic-only mode. ClaudeService.isEnabled() returns
# false, every persona-mediated call (FIDIC draft, clash proposer, monthly
# narrative prose, Anthropic-backed integration tests) is skipped or throws a
# helpful "ANTHROPIC_API_KEY missing — running deterministic-only" error
# rather than silently returning bogus content. All Wave 1 / Cycle 1-4
# deterministic rules, governance state, and append-only history keep working.
#
# DO NOT commit a real key. Hostinger production sets these via env, not file.
# ─────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Default model used when a Persona's modelTier slug ("claude-sonnet") needs to
# be resolved to a concrete model id. Override per-persona on the row itself.
# ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-5
# Default tier slug used when a call does not pin a persona modelTier.
# ANTHROPIC_DEFAULT_TIER=claude-sonnet
# Default max tokens for completions when the caller does not pass its own.
# ANTHROPIC_MAX_TOKENS=4096
# cache_control: { type: 'ephemeral', ttl: <seconds> } applied to every persona
# system prompt so subsequent calls in the same hour hit the cached system block
# and skip re-reading the full persona body. 3600 = 1 hour (Anthropic max for
# the standard ephemeral breakpoint).
# ANTHROPIC_CACHE_TTL=3600
# LLM Council (multi-member adjudication). When ANTHROPIC_COUNCIL_ENABLED=true,
# AI adjudications default to a council of N members + a synthesizing chair
# (more reliable judgement, explicit dissent). Callers can also opt in per-call.
# ANTHROPIC_COUNCIL_ENABLED=false
# ANTHROPIC_COUNCIL_SIZE=3

# ─────────────────────────────────────────────────────────────────────────────
# Autodesk Platform Services (APS / "Forge") — BIM / Revit / IFC integration.
#
# 2-legged OAuth (client_credentials). When BOTH values are empty, the BIM
# surface stays on the local hand-rolled IFC parser; with them set, the platform
# translates Revit/IFC models via Model Derivative and extracts element
# quantities into the Quantity-Survey → Cost → Governance pipeline.
#
# Get credentials by creating an app at https://aps.autodesk.com/myapps (free
# developer account). PREFERRED: set these from the in-app /admin/settings screen
# (encrypted at rest). The env vars below are only a fallback for headless boots.
# DO NOT commit a real secret.
# ─────────────────────────────────────────────────────────────────────────────
# AUTODESK_CLIENT_ID=
# AUTODESK_CLIENT_SECRET=
# Override only for sovereign/region-specific APS hosts.
# AUTODESK_BASE_URL=https://developer.api.autodesk.com

# ─────────────────────────────────────────────────────────────────────────────
# Primavera P6 EPPM REST — LIVE schedule pull (in addition to .xer/.xml/.pdf
# upload + the inbound webhook). When unset, P6 data arrives only by file.
# baseUrl is the P6 EPPM REST root, e.g. https://<host>/p6ws/restapi
# PREFERRED: set these from /admin/settings (encrypted at rest). DO NOT commit
# a real password.
# ─────────────────────────────────────────────────────────────────────────────
# P6_BASE_URL=https://p6.example.com/p6ws/restapi
# P6_DATABASE=
# P6_USERNAME=
# P6_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# S3 / S3-compatible object storage for the file archive (optional). When the
# bucket + access key + secret are set, StorageService writes/reads files on S3
# instead of the local disk. Works with AWS S3 or S3-compatible providers
# (Hetzner, MinIO, Backblaze, Wasabi) via S3_ENDPOINT + S3_FORCE_PATH_STYLE.
# The DB backup script (scripts/backup-db-to-s3.ts) uploads dumps to the same bucket.
# ─────────────────────────────────────────────────────────────────────────────
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# Leave empty for AWS S3; set for S3-compatible providers (e.g. https://s3.eu-central-1.example.com).
# S3_ENDPOINT=
# Path-style addressing — true for most S3-compatible providers, false for AWS.
# S3_FORCE_PATH_STYLE=true
# Optional "system folder" — a top-level key prefix inside the bucket. All file
# archive objects AND DB backups go under it (e.g. sigma-system/…). Leave empty
# for the bucket root. Cloudflare R2 example: S3_REGION=auto, S3_FORCE_PATH_STYLE=true,
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# S3_PREFIX=sigma-system

# ─────────────────────────────────────────────────────────────────────────────
# Stripe billing (multi-tenant SaaS subscriptions, optional). When the secret
# key + price id are set, company registration goes to Stripe Checkout with a
# free trial (STRIPE_TRIAL_DAYS, default 30) — the card is captured up front and
# charged automatically when the trial ends. A signed webhook keeps the local
# subscription/company status in sync. Leave empty in dev to use the trial-only
# flow (registration routes straight to the company login). NEVER commit real keys.
# ─────────────────────────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_PRICE_ID=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_TRIAL_DAYS=30
# Public URL of the frontend (Checkout success/cancel redirects + company login links).
# APP_PUBLIC_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# Database backups → S3/R2. Runs automatically every night (BackupService @Cron,
# in-app, pure mysql2 — no mysqldump needed) and on-demand from the super-admin
# console (POST /backup/run). Also available as CLI: scripts/backup-db-to-s3.ts
# + restore-db-from-s3.ts (these need mysqldump). Files already live on S3 via
# StorageService, so the two together back up EVERYTHING — files + data.
# The dump holds EVERY tenant's data — set BACKUP_ENCRYPTION_KEY so it is
# AES-256-GCM encrypted before upload (generate: `openssl rand -hex 32`). The
# same key is needed to restore. Optionally set S3_SSE=AES256 for server-side
# at-rest encryption (AWS S3; some S3-compatible providers don't support it).
# Use scripts/migrate-storage-to-s3.ts once to push pre-existing local files up.
# See docs/BACKUP-RESTORE.md for scheduling + restore drills.
# ─────────────────────────────────────────────────────────────────────────────
# BACKUP_RETENTION=14
# BACKUP_ENCRYPTION_KEY=
# S3_SSE=AES256
